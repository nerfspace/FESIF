# eBay Listing Monitor – Environment Variables
# Copy this file to .env and fill in the values

# Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SQLite database path
DB_PATH=./fesif.db

# Poller settings (seconds)
POLL_INTERVAL_MIN=5
POLL_INTERVAL_MAX=15

# eBay search keyword(s) – comma-separated list
# Use specific keywords that catch underpriced listings from inexperienced sellers.
# NOTE: blank keywords are NOT supported by the eBay Browse API.
# Good keywords: brand names, "lot of", "estate sale", "moving sale", "untested", "for parts"
EBAY_SEARCH_KEYWORD=iphone,gpu,macbook pro,ps5,nintendo switch,gaming laptop,airpods,rtx 4090,vintage lens,lot of,estate sale,moving sale,untested,for parts

# eBay API credentials (get from https://developer.ebay.com)
# When set, the poller uses the official Browse API instead of HTML scraping.
# If not set, the app falls back to HTML scraping automatically.
EBAY_APP_ID=
EBAY_CERT_ID=

# Daily eBay API call limit (default 5000). Split 30% polling / 70% comps.
EBAY_API_DAILY_LIMIT=5000

# Minimum deal score returned by the API
MIN_DEAL_SCORE=80

# API port
API_PORT=3000

# Optional: comma-separated proxy list  (e.g. http://user:pass@host:port)
# PROXIES=http://proxy1:8080,http://proxy2:8080