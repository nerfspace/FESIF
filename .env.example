# eBay Listing Monitor – Environment Variables
# Copy this file to .env and fill in the values

# Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SQLite database path
DB_PATH=./fesif.db

# Poller settings (seconds)
POLL_INTERVAL_MIN=5
POLL_INTERVAL_MAX=15

# eBay search keyword (blank = all categories)
EBAY_SEARCH_KEYWORD=

# Minimum deal score returned by the API
MIN_DEAL_SCORE=80

# API port
API_PORT=3000

# Optional: comma-separated proxy list  (e.g. http://user:pass@host:port)
# PROXIES=http://proxy1:8080,http://proxy2:8080
